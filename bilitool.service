[Unit]
Description=Gunicorn instance to serve BiliTool
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/bilitool
Environment="PATH=/var/www/bilitool/venv/bin"
EnvironmentFile=/var/www/bilitool/.env
ExecStart=/var/www/bilitool/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 biliTool.wsgi:application
ExecReload=/bin/kill -s HUP $MAINPID
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
